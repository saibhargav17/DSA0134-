//================ MAIN ==================
int main()
{
    try
    {
        double amount;

        cout << "Enter Initial Balance : ";
        cin >> amount;

        if(amount < 1000)
            throw "Minimum balance should be Rs.1000";

        // Dynamic Memory Allocation
        Account *obj =
        new PremiumSavings("Yashwanth",1001,amount);

        obj->display();

        obj->deposit(5000);
        obj->deposit(1200.50);

        *obj = *obj + 1000;

        obj->calculateInterest();

        cout << "\nAfter Transactions\n";
        obj->display();

        save(obj);

        delete obj;
    }

    catch(const char *msg)
    {
        cout << "\nException : " << msg;
    }

    return 0;
}
